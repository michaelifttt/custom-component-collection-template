<!DOCTYPE html>
<html>
<head>
  <style>
    body { margin: 0; padding: 0; }
    #guru-card { width: 100%; height: 100%; }
  </style>
</head>
<body>
  <div id="guru-card"></div>

  <script>
    function loadCard(cardId) {
      if (!cardId) return;

      document.getElementById('guru-card').innerHTML = '';

      window.GuruWidgetConfig = {
        cardId: cardId,
        container: document.getElementById('guru-card')
      };

      const old = document.getElementById('guru-script');
      if (old) old.remove();

      const script = document.createElement('script');
      script.id = 'guru-script';
      script.src = 'https://app.getguru.com/static/widget.js';
      document.body.appendChild(script);
    }

    window.Retool.subscribe(function(model) {
      loadCard(model.cardId);
    });
  </script>
</body>
</html>